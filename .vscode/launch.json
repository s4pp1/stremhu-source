{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Server (Nest.js)",
      "runtimeExecutable": "${workspaceFolder}/.conda/bin/npm",
      "runtimeArgs": ["run", "start:debug", "--", "--inspect-brk"],
      "cwd": "${workspaceFolder}/server",
      "autoAttachChildProcesses": true,
      "restart": true,
      "sourceMaps": true,
      "stopOnEntry": false,
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Client (React.js)",
      "cwd": "${workspaceFolder}/client",
      "runtimeExecutable": "${workspaceFolder}/.conda/bin/npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Relay (FastApi)",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "4300",
        "--reload",
        "--log-config",
        "../logging.ini"
      ],
      "cwd": "${workspaceFolder}/relay/src",
      "subProcess": true,
      "jinja": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/relay/src"
      }
    }
  ]
}
