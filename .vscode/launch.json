{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "debugpy",
      "request": "launch",
      "name": "Server (FastApi)",
      "program": "${workspaceFolder}/server/app/run.py",
      "cwd": "${workspaceFolder}/server",
      "subProcess": true,
      "jinja": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/server"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Client (React.js)",
      "cwd": "${workspaceFolder}/client",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Local:\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
